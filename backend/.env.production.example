# Backend production environment
# Set these in Render/Railway service environment variables.

NODE_ENV=production
PORT=5000

# Legacy MongoDB routes still use this during the transition.
# Keep it while /api/shelves and /api/shipments are still Mongo-backed.
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/inventrack

# Frontend origin for CORS. Replace with your Vercel production URL.
CORS_ORIGIN=https://inventrack.vercel.app

# Optional: only needed for AI recommendation route.
OPENAI_API_KEY=your_openai_api_key

# PostgreSQL v2 API database.
# Used by /api/v2/* routes.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/inventrack?sslmode=require
