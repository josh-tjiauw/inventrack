# Production environment for local dev (optional, not required on Vercel)
# Set this to point to your local backend during development:
# REACT_APP_API_BASE_URL=http://localhost:5000
# Or point to your Render backend for testing without Vercel:
# REACT_APP_API_BASE_URL=https://inventrack-api-v2l8.onrender.com
# Leave unset on Vercel to auto-use https://inventrack-api-v2l8.onrender.com
